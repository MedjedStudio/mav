# バックエンド用環境変数テンプレート

# バックエンド設定
DEBUG=true
JWT_SECRET_KEY=change-this-to-a-secure-secret-key
JWT_EXPIRE_HOURS=24

# データベース設定
DATABASE_URL=mysql+pymysql://mav_user:change-this-password@localhost:3306/mav_db

# CORS設定（カンマ区切りで複数指定可能）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com

# ファイル配信用ベースURL（本番環境用）
BASE_URL=https://your-domain.com
