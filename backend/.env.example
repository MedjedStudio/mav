# バックエンド用環境変数テンプレート

# 必須環境変数
JWT_SECRET_KEY=change-this-to-a-secure-secret-key
JWT_EXPIRE_HOURS=24

# データベース接続設定
MYSQL_USER=mav_user
MYSQL_PASSWORD=change-this-password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=mav_db

# CORS設定
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com
BASE_URL=https://your-domain.com

# サーバー設定
DEBUG=true
HOST=0.0.0.0
PORT=8000
